cmake_minimum_required(VERSION 3.19)
project(isophine LANGUAGES CXX)

find_package(Qt6 6.5 REQUIRED COMPONENTS Core Widgets Pdf)

qt_standard_project_setup()

qt_add_executable(isophine
    WIN32 MACOSX_BUNDLE
    main.cpp
    isophine_editor.cpp
    isophine_editor.h
    isophine_editor.ui
    superspinbox.cpp
    superspinbox.h
    pageviewer.cpp
    pageviewer.h
    project_settings.cpp
    project_settings.h



)

target_link_libraries(isophine
    PRIVATE
        Qt::Core
        Qt::Widgets
        Qt::Pdf
)
target_include_directories(isophine PRIVATE ${CMAKE_CURRENT_SOURCE_DIR})

install(TARGETS isophine
    BUNDLE  DESTINATION .
    RUNTIME DESTINATION ${CMAKE_INSTALL_BINDIR}
    LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR}
)

qt_generate_deploy_app_script(
    TARGET isophine
    OUTPUT_SCRIPT deploy_script
    NO_UNSUPPORTED_PLATFORM_ERROR
)
install(SCRIPT ${deploy_script})
